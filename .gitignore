replay_pid*.log

# --- Frontend (Node / Vite) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/coverage/
frontend/*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- 根目录若产生日志或临时文件 ---
/logs/
/tmp/
*.tmp
*.bak
